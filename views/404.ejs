<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/landing.css">
</head>
<body style="min-height:100vh;display:grid;place-items:center;text-align:center;background:#f4f8f5">
  <div>
    <div style="font-family:var(--font-display);font-size:80px;font-weight:760;color:var(--green)">404</div>
    <h1 style="font-size:24px;margin:8px 0 6px">Página não encontrada</h1>
    <p style="color:var(--soft);margin-bottom:22px">O empreendimento que você procura não existe ou foi removido.</p>
    <a href="/" style="display:inline-block;background:linear-gradient(160deg,var(--green),var(--green-deep));color:#fff;font-weight:640;padding:12px 22px;border-radius:12px">Voltar ao início</a>
  </div>
</body>
</html>
