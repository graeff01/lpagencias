# ===== Auxiliadora Landings — variáveis de ambiente =====

# Senha do painel /admin (obrigatório em produção)
ADMIN_PASSWORD=troque-esta-senha

# Segredo dos cookies de sessão (qualquer string longa e aleatória)
SESSION_SECRET=coloque-uma-string-longa-e-aleatoria-aqui

# Banco de dados PostgreSQL (o Railway injeta automaticamente ao adicionar o Postgres)
# Em local, se deixar vazio, o app usa um banco em memória (pg-mem) só para testes.
DATABASE_URL=

# Cloudinary — upload das fotos dos empreendimentos (crie conta grátis em cloudinary.com)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Porta (o Railway define automaticamente; local usa 3000)
PORT=3000
